# Copy this file to .env and fill in your values.
# On Railway / Render / GitHub Actions, set these as environment variables instead.

# Neon Postgres connection string (Neon dashboard → Connection Details)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# OpenAI API key for LLM-based entry categorization (platform.openai.com/api-keys)
# If unset, tagging is skipped and entries are stored with empty tags.
OPENAI_API_KEY=sk-...

# OpenAI model to use for tagging. Defaults to gpt-4o-mini if not set.
# Options (cost order, cheapest first): gpt-4o-mini, gpt-4.1-mini, gpt-4.1, gpt-4o

